{
  "name": "markbook-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Lightweight Storybook alternative — markdown-driven, framework-agnostic",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter '@markbook/core' --filter 'markbook' test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "prepare": "husky",
    "example:build": "pnpm --filter @markbook/example-react-demo build",
    "example:dev": "pnpm --filter @markbook/example-react-demo dev",
    "example:bundle": "pnpm --filter @markbook/example-react-demo exec markbook bundle",
    "example:bundle:package": "pnpm --filter @markbook/example-react-demo exec markbook bundle --mode package",
    "example:vue:build": "pnpm --filter @markbook/example-vue-demo build",
    "example:vue:dev": "pnpm --filter @markbook/example-vue-demo dev",
    "example:vue:bundle": "pnpm --filter @markbook/example-vue-demo exec markbook bundle",
    "example:vue:bundle:package": "pnpm --filter @markbook/example-vue-demo exec markbook bundle --mode package",
    "example:wc:build": "pnpm --filter @markbook/example-wc-demo build",
    "example:wc:dev": "pnpm --filter @markbook/example-wc-demo dev",
    "example:wc:bundle": "pnpm --filter @markbook/example-wc-demo exec markbook bundle",
    "example:wc:bundle:package": "pnpm --filter @markbook/example-wc-demo exec markbook bundle --mode package",
    "example:static:build": "pnpm --filter @markbook/example-static-demo build",
    "example:static:dev": "pnpm --filter @markbook/example-static-demo dev",
    "example:marketing:build": "pnpm --filter @markbook/example-marketing-demo build",
    "example:marketing:dev": "pnpm --filter @markbook/example-marketing-demo dev",
    "example:marketing:preview": "pnpm --filter @markbook/example-marketing-demo exec markbook preview",
    "examples:dev": "node scripts/examples-dev.mjs",
    "examples:build": "pnpm --filter './examples/*' --parallel build",
    "example:embed-host:build": "pnpm example:build && pnpm example:bundle && pnpm example:bundle:package",
    "example:embed-host:serve": "python3 -m http.server 4500 --directory examples"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "concurrently": "^9.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.6.3"
  }
}
