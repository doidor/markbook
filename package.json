{
  "name": "markbook-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Lightweight Storybook alternative — markdown-driven, framework-agnostic",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r typecheck",
    "example:build": "pnpm --filter @markbook/example-react-demo build"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
