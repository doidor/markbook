{
  "name": "@doidor/markbook-adapter-react",
  "version": "0.1.2",
  "description": "React mount adapter for Markbook",
  "keywords": [
    "markbook",
    "react",
    "storybook-alternative",
    "stories",
    "adapter"
  ],
  "license": "MIT",
  "author": "doidor",
  "homepage": "https://doidor.github.io/markbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doidor/markbook.git",
    "directory": "packages/adapter-react"
  },
  "bugs": {
    "url": "https://github.com/doidor/markbook/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@doidor/markbook-adapter-shared": "workspace:*",
    "@doidor/markbook-core": "workspace:*",
    "@vitejs/plugin-react": "^4.3.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
