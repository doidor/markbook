{
  "name": "@doidor/markbook-adapter-shared",
  "version": "0.1.1",
  "description": "Shared browser-side runtime helpers for Markbook framework adapters (CSS injection, shadow-root mounting, story parameters)",
  "keywords": [
    "markbook",
    "adapter",
    "runtime"
  ],
  "license": "MIT",
  "author": "doidor",
  "homepage": "https://doidor.github.io/markbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doidor/markbook.git",
    "directory": "packages/adapter-shared"
  },
  "bugs": {
    "url": "https://github.com/doidor/markbook/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc --noEmit"
