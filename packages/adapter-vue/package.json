{
  "name": "@markbook/adapter-vue",
  "version": "0.0.0",
  "description": "Vue 3 mount adapter for Markbook",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@markbook/core": "workspace:*",
    "@vitejs/plugin-vue": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vue": "^3.4.0"
  }
}
