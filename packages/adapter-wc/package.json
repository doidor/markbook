{
  "name": "@markbook/adapter-wc",
  "version": "0.0.0",
  "description": "Web Components mount adapter for Markbook",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@markbook/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
