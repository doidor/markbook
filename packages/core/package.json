{
  "name": "@doidor/markbook-core",
  "version": "0.4.1",
  "description": "Markbook core — markdown parsing, story extraction, static site building",
  "keywords": [
    "markbook",
    "markdown",
    "documentation",
    "static-site-generator",
    "vite",
    "remark",
    "stories"
  ],
  "license": "MIT",
  "author": "doidor",
  "homepage": "https://doidor.github.io/markbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doidor/markbook.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/doidor/markbook/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "gray-matter": "^4.0.3",
    "lz-string": "^1.5.0",
    "pagefind": "^1.3.0",
    "react-docgen-typescript": "^2.2.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^3.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.22.0",
    "tinyglobby": "^0.2.10",
    "typescript": "^5.6.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
