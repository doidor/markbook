{
  "name": "@markbook/core",
  "version": "0.0.0",
  "description": "Markbook core — markdown parsing, story extraction, static site building",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.3.0",
    "react-docgen-typescript": "^2.2.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^3.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.22.0",
    "tinyglobby": "^0.2.10",
    "typescript": "^5.6.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@types/node": "^22.7.0"
  }
}
