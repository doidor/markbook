{
  "name": "@doidor/markbook",
  "version": "0.6.0",
  "description": "Markbook CLI — build static documentation sites from markdown + component stories",
  "keywords": [
    "markbook",
    "cli",
    "documentation",
    "markdown",
    "storybook-alternative",
    "static-site-generator",
    "stories"
  ],
  "license": "MIT",
  "author": "doidor",
  "homepage": "https://doidor.github.io/markbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doidor/markbook.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/doidor/markbook/issues"
  },
  "type": "module",
  "bin": {
