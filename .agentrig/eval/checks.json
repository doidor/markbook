{
  "$schema": "agentrig-harness-checks/1",
  "description": "Deterministic harness audit checks. Each maps a principle to a structural check scored 0 / 0.5 / 1.0. Two layers: \"completeness\" (file/dir structure) and \"quality\" (content sanity probes). Consumed by both `agentrig eval --static` and `node .agentrig/eval/static-audit.mjs`.",
  "checks": [
    {
      "id": "state-machine",
      "principle": 1,
      "title": "Workflow is an explicit, connected state machine (DAG with queued→merged path)",
      "type": "state-machine-dag",
      "path": ".agentrig/harness/state-machine.yml",
      "minStates": 6,
      "requirePath": "queued->merged",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "trigger-taxonomy",
      "principle": 1,
      "title": "Transition trigger taxonomy declared",
      "type": "file-contains",
      "path": ".agentrig/harness/state-machine.yml",
      "patterns": ["triggers:", "event_to_state"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "orchestration-doc",
      "principle": 1,
      "title": "Orchestration contract documented",
      "type": "path-exists",
      "path": ".agentrig/harness/ORCHESTRATION.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "model-tiers",
      "principle": 2,
      "title": "Model tiers defined for cost/quality routing",
      "type": "file-contains",
      "path": ".agentrig/harness/state-machine.yml",
      "patterns": ["model_tiers:", "premium"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "roles-distinct-families",
      "principle": 2,
      "title": "Developer and reviewer use DIFFERENT model families (not just different ids)",
      "type": "roles-distinct-families",
      "developer": ".agentrig/agents/developer.yml",
      "reviewer": ".agentrig/agents/reviewer.yml",
      "key": "model",
      "layer": "quality",
      "weight": 1
    },
    {
      "id": "roles-roster",
      "principle": 2,
      "title": "Multiple specialized agent roles installed",
      "type": "dir-min",
      "path": ".agentrig/agents",
      "min": 6,
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "role-prompts",
      "principle": 2,
      "title": "Roles have dedicated prompts",
      "type": "path-exists",
      "path": ".agentrig/agents/developer.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "system-of-record",
      "principle": 3,
      "title": "GitHub labels mirror DAG state",
      "type": "file-contains",
      "path": ".agentrig/harness/state-machine.yml",
      "patterns": ["labels:", "state_map"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "reconciliation",
      "principle": 3,
      "title": "Reconciliation + recovery policy declared",
      "type": "file-contains",
      "path": ".agentrig/harness/state-machine.yml",
      "patterns": ["reconciliation:", "recovery:", "claim_grace_seconds"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "dashboard",
      "principle": 3,
      "title": "Harness dashboard surfaces GitHub task state",
      "type": "path-exists",
      "path": ".agentrig/dashboard/dashboard.mjs",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "skills-present",
      "principle": 4,
      "title": "Skills directory has procedural memory",
      "type": "dir-min",
      "path": ".agents/skills",
      "min": 3,
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "skill-frontmatter-all",
      "principle": 4,
      "title": "Every skill declares description + allowed-tools (not just self-verify)",
      "type": "frontmatter-keys-all",
      "path": ".agents/skills",
      "file": "SKILL.md",
      "keys": ["description", "allowed-tools"],
      "layer": "quality",
      "weight": 1
    },
    {
      "id": "rules-present",
      "principle": 4,
      "title": "Glob-scoped rules with priority order",
      "type": "path-exists",
      "path": ".agents/rules/README.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "default-rules",
      "principle": 4,
      "title": "Security + code-review reflex rules installed",
      "type": "dir-min",
      "path": ".agents/rules",
      "min": 4,
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "self-verify",
      "principle": 5,
      "title": "Self-verify-before-handoff skill",
      "type": "path-exists",
      "path": ".agents/skills/self-verify/SKILL.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "eval-rubric",
      "principle": 6,
      "title": "Rubric-driven evaluation present",
      "type": "path-exists",
      "path": ".agentrig/eval/RUBRIC.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "eval-axes",
      "principle": 6,
      "title": "Validated axis/issue-code registry present",
      "type": "path-exists",
      "path": ".agentrig/eval/axes.json",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "eval-axes-coherent",
      "principle": 6,
      "title": "axes.json has at least one issue code per axis",
      "type": "quality-probe",
      "probe": "axes-json-coherent",
      "path": ".agentrig/eval/axes.json",
      "layer": "quality",
      "weight": 1
    },
    {
      "id": "eval-checks-coherent",
      "principle": 6,
      "title": "checks.json has unique ids and only known check types",
      "type": "quality-probe",
      "probe": "checks-json-coherent",
      "path": ".agentrig/eval/checks.json",
      "layer": "quality",
      "weight": 1
    },
    {
      "id": "eval-sandbox",
      "principle": 6,
      "title": "Eval sandbox guardrails present",
      "type": "path-exists",
      "path": ".agentrig/eval/sandbox/eval-rules.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "eval-harness-skill",
      "principle": 6,
      "title": "Harness-eval skill present",
      "type": "path-exists",
      "path": ".agents/skills/harness-eval/SKILL.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "worktrees",
      "principle": 7,
      "title": "Hermetic per-agent worktree script",
      "type": "path-exists",
      "path": "scripts/repair-worktrees.sh",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "wiki",
      "principle": 8,
      "title": "Tiered memory / wiki",
      "type": "path-exists",
      "path": ".agents/wiki/README.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "wiki-router",
      "principle": 8,
      "title": "Wiki index/router + troubleshooting present",
      "type": "path-exists",
      "path": ".agents/wiki/index.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "skill-improver",
      "principle": 8,
      "title": "Skill-improver closes the feedback loop",
      "type": "path-exists",
      "path": ".agents/skills/skill-improver/SKILL.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "human-gates",
      "principle": 9,
      "title": "Human-only gates declared",
      "type": "file-contains",
      "path": ".agentrig/harness/state-machine.yml",
      "patterns": ["human_only", "human"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "hard-limits",
      "principle": 10,
      "title": "Hard limits and safety nets",
      "type": "file-contains",
      "path": ".agentrig/harness/state-machine.yml",
      "patterns": ["limits:", "max_diff_chars", "runaway_token_cap"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "mcp",
      "principle": 11,
      "title": "Tooling neutrality via MCP",
      "type": "path-exists",
      "path": ".mcp.json",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "surfaces",
      "principle": 11,
      "title": "Vendor surfaces mirror one canonical source",
      "type": "path-exists",
      "path": ".claude",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "copilot-instructions",
      "principle": 11,
      "title": "GitHub Copilot instructions projected (remote + IDE)",
      "type": "path-exists",
      "path": ".github/copilot-instructions.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "github-instructions",
      "principle": 11,
      "title": "Path-scoped .github/instructions projected from rules",
      "type": "dir-min",
      "path": ".github/instructions",
      "min": 1,
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "claude-md",
      "principle": 11,
      "title": "CLAUDE.md projected for Claude Code",
      "type": "path-exists",
      "path": "CLAUDE.md",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "cursor-rules",
      "principle": 11,
      "title": "Cursor rules (.cursor/rules) projected from rules",
      "type": "dir-min",
      "path": ".cursor/rules",
      "min": 1,
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "copilot-setup-steps",
      "principle": 11,
      "title": "Copilot coding-agent environment scaffolded",
      "type": "path-exists",
      "path": ".github/workflows/copilot-setup-steps.yml",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "agents-critical-rules",
      "principle": 12,
      "title": "AGENTS.md leads with Critical Rules",
      "type": "file-contains",
      "path": "AGENTS.md",
      "patterns": ["Critical Rules"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "agents-context",
      "principle": 12,
      "title": "AGENTS.md captures repo context",
      "type": "file-contains",
      "path": "AGENTS.md",
      "patterns": ["What this repository is"],
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "agents-skills-inventory",
      "principle": 12,
      "title": "AGENTS.md skills-inventory block is POPULATED (not just present) with every installed skill",
      "type": "marker-populated",
      "path": "AGENTS.md",
      "marker": "skills-inventory",
      "enumerateDir": ".agents/skills",
      "layer": "completeness",
      "weight": 1
    },
    {
      "id": "agents-no-unfilled-placeholders",
      "principle": 12,
      "title": "AGENTS.md has no unfilled {{PLACEHOLDER}} tokens",
      "type": "quality-probe",
      "probe": "no-unfilled-placeholders",
      "path": "AGENTS.md",
      "layer": "quality",
      "weight": 1
    },
    {
      "id": "context-md-present",
      "principle": 12,
      "title": ".agentrig/context.md exists (proves init actually investigated)",
      "type": "quality-probe",
      "probe": "context-md-present",
      "path": ".agentrig/context.md",
      "layer": "quality",
      "weight": 1
    }
  ]
}
